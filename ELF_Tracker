#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
    LINK_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$LINK_DIR/$SCRIPT_PATH"
done

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
CORE_DIR="$SCRIPT_DIR/core"
ENFORCE_SRC="$CORE_DIR/shadow_stack.c"
ENFORCE_SO="$CORE_DIR/libshadow_stack.so"
DR_DIR="${ET_DYNAMORIO_DIR:-$SCRIPT_DIR/dynamorio-min}"
POLICY_PATH="${ET_CSCFI_POLICY:-$SCRIPT_DIR/policy/default.policy}"
ENFORCE_MODE="${ET_CSCFI_ENFORCE_MODE:-main}"
SEED="${ET_CSCFI_SEED:-}"

print_help() {
    cat <<EOF
Usage:
  ELF_Tracker [options] <target-binary> [target-args...]

Description:
  Run the target under the enforcement client with shadow stack and CFI checks.

Options:
  --main                Use main-only CSCFI enforcement. This is the default.
  --strong              Use strong CSCFI enforcement, including shared libraries.
  --policy <file>       Policy file path to load.
  --seed <value>        Hash seed. Must match the value used in training.
  --dr-dir <dir>        DynamoRIO root directory.
  -h, --help            Show this help message.

Arguments:
  <target-binary>        Executable target to protect.
  [target-args...]       Optional arguments passed to the target.

Environment:
  ET_DYNAMORIO_DIR       Override DynamoRIO root directory.
                         Default: $DR_DIR
  ET_CSCFI_POLICY        Policy file path to load.
                         Default: $POLICY_PATH
  ET_CSCFI_ENFORCE_MODE  Enforcement scope: main or strong.
                         Default: $ENFORCE_MODE
  ET_CSCFI_SEED          Optional hash seed. Must match the value used in training.

Examples:
  ELF_Tracker ./poc
  ELF_Tracker ./test.out
  ELF_Tracker --policy ./policy/poc.policy ./poc
  ELF_Tracker --strong --policy ./policy/poc2.policy ./poc2
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            print_help
            exit 0
            ;;
        --main)
            ENFORCE_MODE="main"
            shift
            ;;
        --strong)
            ENFORCE_MODE="strong"
            shift
            ;;
        --policy)
            if [[ $# -lt 2 ]]; then
                echo "[enforce] missing value for --policy" >&2
                exit 1
            fi
            POLICY_PATH="$2"
            shift 2
            ;;
        --seed)
            if [[ $# -lt 2 ]]; then
                echo "[enforce] missing value for --seed" >&2
                exit 1
            fi
            SEED="$2"
            shift 2
            ;;
        --dr-dir)
            if [[ $# -lt 2 ]]; then
                echo "[enforce] missing value for --dr-dir" >&2
                exit 1
            fi
            DR_DIR="$2"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "[enforce] unknown option: $1" >&2
            echo "[enforce] try: ELF_Tracker --help" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

DRRUN="$DR_DIR/bin64/drrun"

if [[ $# -lt 1 ]]; then
    print_help >&2
    exit 1
fi

TARGET_BIN="$1"
shift

if [[ ! -x "$DRRUN" ]]; then
    echo "[enforce] drrun not found: $DRRUN" >&2
    exit 1
fi

if [[ ! -f "$ENFORCE_SRC" ]]; then
    echo "[enforce] source not found: $ENFORCE_SRC" >&2
    exit 1
fi

if [[ ! -x "$TARGET_BIN" ]]; then
    echo "[enforce] target not executable: $TARGET_BIN" >&2
    exit 1
fi

if [[ ! -f "$POLICY_PATH" ]]; then
    echo "[enforce] policy file not found: $POLICY_PATH" >&2
    exit 1
fi

if [[ ! -f "$ENFORCE_SO" || "$ENFORCE_SRC" -nt "$ENFORCE_SO" ]]; then
    echo "[enforce] building enforcement client..."
    gcc -shared -fPIC -O2 -DNDEBUG -DLINUX -DX86_64 \
        "$ENFORCE_SRC" -o "$ENFORCE_SO" \
        -I"$DR_DIR/include" -I"$DR_DIR/ext/include" \
        -L"$DR_DIR/lib64/release" -L"$DR_DIR/ext/lib64/release" \
        -ldynamorio -ldrmgr \
        -Wl,-rpath,'$ORIGIN/../dynamorio-min/lib64/release:$ORIGIN/../dynamorio-min/ext/lib64/release'
else
    echo "[enforce] reusing existing enforcement client: $ENFORCE_SO"
fi

echo "[enforce] running target under defense..."
ET_CSCFI_POLICY="$POLICY_PATH" \
ET_CSCFI_ENFORCE_MODE="$ENFORCE_MODE" \
ET_CSCFI_SEED="$SEED" \
"$DRRUN" -c "$ENFORCE_SO" -- "$TARGET_BIN" "$@"
